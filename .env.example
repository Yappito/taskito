# PostgreSQL
POSTGRES_USER="taskito"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="taskito"

# Auth.js
AUTH_URL="https://taskito.example.com"
AUTH_SECRET="replace-with-a-cryptographically-strong-secret"

# Optional auto-tagger (OpenAI-compatible API)
AUTO_TAGGER_URL=""
AUTO_TAGGER_API_KEY=""

# AI provider secret encryption (base64-encoded 32-byte key)
AI_SECRET_MASTER_KEY=""

# Optional comma-separated AI provider host allowlist
AI_PROVIDER_HOST_ALLOWLIST=""

# Optional AI provider request timeout in milliseconds
AI_PROVIDER_REQUEST_TIMEOUT_MS="90000"

# Optional: set to true only when you intentionally want demo data
ALLOW_DEMO_SEED="false"
