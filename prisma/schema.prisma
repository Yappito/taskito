// This is your Prisma schema file for Taskito.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("member")
  settings      Json      @default("{}")
  accounts      Account[]
  sessions      Session[]
  comments      Comment[]
  activityEvents ActivityEvent[]
  watchingTasks TaskWatcher[]
  notifications Notification[] @relation("NotificationRecipient")
  notificationActors Notification[] @relation("NotificationActor")
  createdTasks  Task[]    @relation("TaskCreator")
  assignedTasks Task[]    @relation("TaskAssignee")
  projectMemberships ProjectMember[]
  ownedAiProviders AiProviderConnection[] @relation("OwnedAiProviders")
  aiConversations AiConversation[] @relation("CreatedAiConversations")
  requestedAiActionExecutions AiActionExecution[] @relation("RequestedAiActions")
  executedAiActionExecutions AiActionExecution[] @relation("ExecutedAiActions")
  rolledBackAiActionExecutions AiActionExecution[] @relation("RolledBackAiActions")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Project ─────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  key         String   @unique
  description String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  statuses    WorkflowStatus[]
  transitions WorkflowTransition[]
  tasks       Task[]
  tags        Tag[]
  customFields CustomField[]
  members     ProjectMember[]
  aiProviders AiProviderConnection[]
  aiPolicy    AiProjectPolicy?
  aiConversations AiConversation[]
  aiActionExecutions AiActionExecution[]
}

enum ProjectMemberRole {
  owner
  member
}

model ProjectMember {
  projectId  String
  userId     String
  role       ProjectMemberRole @default(member)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
}

// ─── Workflow ────────────────────────────────────────────

enum StatusCategory {
  backlog
  todo
  active
  done
  cancelled
}

model WorkflowStatus {
  id              String         @id @default(cuid())
  projectId       String
  name            String
  color           String         @default("#6b7280")
  order           Int            @default(0)
  category        StatusCategory @default(todo)
  isFinal         Boolean        @default(false)
  autoArchive     Boolean        @default(false)
  autoArchiveDays Int            @default(0)

  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks           Task[]
  fromTransitions WorkflowTransition[] @relation("FromStatus")
  toTransitions   WorkflowTransition[] @relation("ToStatus")

  @@unique([projectId, name])
  @@index([projectId, order])
}

model WorkflowTransition {
  id           String @id @default(cuid())
  projectId    String
  fromStatusId String
  toStatusId   String

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStatus WorkflowStatus @relation("FromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus   WorkflowStatus @relation("ToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([projectId, fromStatusId, toStatusId])
}

// ─── Task ────────────────────────────────────────────────

enum TaskPriority {
  none
  low
  medium
  high
  urgent
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  taskNumber  Int
  creatorId   String?
  assigneeId  String?
  title       String
  description Json?
  body        String?      @db.Text
  statusId    String
  priority    TaskPriority @default(none)
  dueDate     DateTime
  startDate   DateTime?
  closedAt    DateTime?
  archivedAt  DateTime?
  alertAcknowledged Boolean @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator          User?              @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  assignee         User?              @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  status           WorkflowStatus     @relation(fields: [statusId], references: [id])
  tags             TaskTag[]
  sourceLinks      TaskLink[]         @relation("SourceTask")
  targetLinks      TaskLink[]         @relation("TargetTask")
  comments         Comment[]
  activityEvents   ActivityEvent[]
  watchers         TaskWatcher[]
  notifications    Notification[]
  customFieldValues CustomFieldValue[]
  aiConversations  AiConversation[]
  aiActionExecutions AiActionExecution[]

  @@unique([projectId, taskNumber])
  @@index([projectId, dueDate])
  @@index([projectId, statusId])
  @@index([projectId, archivedAt])
  @@index([projectId, assigneeId])
  @@index([creatorId])
}

enum TaskActivityAction {
  created
  updated
  bulkUpdated
  commented
  archived
  unarchived
  duplicated
}

model ActivityEvent {
  id        String             @id @default(cuid())
  taskId     String
  actorId    String?
  action     TaskActivityAction
  details    Json?
  createdAt  DateTime          @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([actorId])
}

enum NotificationType {
  assigned
  commented
  statusChanged
  mentioned
}

model TaskWatcher {
  taskId     String
  userId     String
  createdAt  DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?
  taskId      String?
  type        NotificationType
  payload     Json             @default("{}")
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  task      Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@index([taskId])
}

// ─── Task Links ──────────────────────────────────────────

enum LinkType {
  blocks
  relates
  parent
  child
}

model TaskLink {
  id           String   @id @default(cuid())
  sourceTaskId String
  targetTaskId String
  linkType     LinkType

  sourceTask Task @relation("SourceTask", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask Task @relation("TargetTask", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId, linkType])
}

// ─── Tags ────────────────────────────────────────────────

model Tag {
  id              String    @id @default(cuid())
  projectId       String
  name            String
  color           String    @default("#6b7280")
  isAutoGenerated Boolean   @default(false)

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskTag[]

  @@unique([projectId, name])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

// ─── Comments ────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  task        Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author      User                @relation(fields: [authorId], references: [id])
  attachments CommentAttachment[]

  @@index([taskId, createdAt])
}

model CommentAttachment {
  id           String   @id @default(cuid())
  commentId    String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  createdAt    DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId, createdAt])
}

// ─── Custom Fields ───────────────────────────────────────

enum CustomFieldType {
  text
  number
  date
  select
}

model CustomField {
  id        String          @id @default(cuid())
  projectId String
  name      String
  type      CustomFieldType
  order     Int             @default(0)
  required  Boolean         @default(false)
  options   Json?

  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  values  CustomFieldValue[]

  @@unique([projectId, name])
  @@index([projectId, order])
}

model CustomFieldValue {
  id            String @id @default(cuid())
  taskId        String
  customFieldId String
  value         Json

  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([taskId, customFieldId])
}

enum AiProviderScope {
  user
  project
}

enum AiProviderAdapter {
  openai_compatible
  anthropic
}

enum AiConversationMode {
  approval
  yolo
}

enum AiMessageRole {
  system
  user
  assistant
  tool
}

enum AiActionStatus {
  proposed
  approved
  rejected
  executed
  failed
}

enum AiRollbackStatus {
  unavailable
  available
  rolledBack
  failed
}

enum AiActionType {
  addComment
  addLink
  removeLink
  moveStatus
  assignTask
  editTask
  bulkUpdate
  createTask
  duplicateTask
  archiveTask
  unarchiveTask
}

model AiProviderConnection {
  id              String            @id @default(cuid())
  scope           AiProviderScope
  ownerUserId     String?
  projectId       String?
  label           String
  adapter         AiProviderAdapter
  baseUrl         String
  model           String
  encryptedSecret String
  defaultHeaders  Json?
  isEnabled       Boolean           @default(true)
  isDefault       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  ownerUser User? @relation("OwnedAiProviders", fields: [ownerUserId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversations AiConversation[]
  defaultForProjectPolicies AiProjectPolicy[] @relation("AiPolicyDefaultProvider")

  @@index([ownerUserId])
  @@index([projectId])
}

model AiProjectPolicy {
  projectId          String   @id
  defaultProviderId  String?
  allowUserProviders Boolean  @default(true)
  allowProjectProviders Boolean @default(true)
  allowYoloMode      Boolean  @default(true)
  defaultPermissions Json     @default("[\"read_current_task\",\"read_selected_tasks\",\"search_project\"]")
  maxPermissions     Json     @default("[\"read_current_task\",\"read_selected_tasks\",\"search_project\",\"add_comment\",\"link_tasks\",\"move_status\",\"assign_task\",\"edit_core_fields\",\"edit_tags\",\"edit_custom_fields\",\"bulk_update_selected\",\"create_task\",\"duplicate_task\",\"archive_task\"]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defaultProvider AiProviderConnection? @relation("AiPolicyDefaultProvider", fields: [defaultProviderId], references: [id], onDelete: SetNull)
}

model AiConversation {
  id                 String             @id @default(cuid())
  projectId          String
  taskId             String?
  createdByUserId    String
  providerId         String
  mode               AiConversationMode @default(approval)
  title              String?
  grantedPermissions Json               @default("[]")
  selectedTaskIds    Json?
  contextSnapshot    Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task?                @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdByUser User                 @relation("CreatedAiConversations", fields: [createdByUserId], references: [id], onDelete: Cascade)
  provider      AiProviderConnection @relation(fields: [providerId], references: [id], onDelete: Restrict)
  messages      AiMessage[]
  actionExecutions AiActionExecution[]

  @@index([projectId, updatedAt])
  @@index([taskId])
  @@index([createdByUserId, updatedAt])
}

model AiMessage {
  id             String        @id @default(cuid())
  conversationId String
  role           AiMessageRole
  content        String        @db.Text
  toolName       String?
  toolPayload    Json?
  createdAt      DateTime      @default(now())

  conversation AiConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actionExecutions AiActionExecution[]

  @@index([conversationId, createdAt])
}

model AiActionExecution {
  id                String             @id @default(cuid())
  conversationId    String
  messageId         String?
  projectId         String
  taskId            String?
  requestedByUserId String
  executedByUserId  String?
  actionType        AiActionType
  title             String?
  summary           String?            @db.Text
  mode              AiConversationMode
  status            AiActionStatus     @default(proposed)
  proposedPayload   Json
  executedPayload   Json?
  result            Json?
  checkpointBefore  Json?
  checkpointAfter   Json?
  rollbackStatus    AiRollbackStatus    @default(unavailable)
  rollbackErrorMessage String?           @db.Text
  rolledBackAt      DateTime?
  rolledBackByUserId String?
  errorMessage      String?            @db.Text
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message         AiMessage?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  requestedByUser User            @relation("RequestedAiActions", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  executedByUser  User?           @relation("ExecutedAiActions", fields: [executedByUserId], references: [id], onDelete: SetNull)
  rolledBackByUser User?           @relation("RolledBackAiActions", fields: [rolledBackByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([projectId, createdAt])
  @@index([taskId, createdAt])
  @@index([requestedByUserId, createdAt])
  @@index([rolledBackByUserId, createdAt])
}
