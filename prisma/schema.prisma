// This is your Prisma schema file for Taskito.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("member")
  settings      Json      @default("{}")
  accounts      Account[]
  sessions      Session[]
  comments      Comment[]
  activityEvents ActivityEvent[]
  watchingTasks TaskWatcher[]
  notifications Notification[] @relation("NotificationRecipient")
  notificationActors Notification[] @relation("NotificationActor")
  createdTasks  Task[]    @relation("TaskCreator")
  assignedTasks Task[]    @relation("TaskAssignee")
  projectMemberships ProjectMember[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Project ─────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  key         String   @unique
  description String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  statuses    WorkflowStatus[]
  transitions WorkflowTransition[]
  tasks       Task[]
  tags        Tag[]
  customFields CustomField[]
  members     ProjectMember[]
}

enum ProjectMemberRole {
  owner
  member
}

model ProjectMember {
  projectId  String
  userId     String
  role       ProjectMemberRole @default(member)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
}

// ─── Workflow ────────────────────────────────────────────

enum StatusCategory {
  backlog
  todo
  active
  done
  cancelled
}

model WorkflowStatus {
  id              String         @id @default(cuid())
  projectId       String
  name            String
  color           String         @default("#6b7280")
  order           Int            @default(0)
  category        StatusCategory @default(todo)
  autoArchive     Boolean        @default(false)
  autoArchiveDays Int            @default(0)

  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks           Task[]
  fromTransitions WorkflowTransition[] @relation("FromStatus")
  toTransitions   WorkflowTransition[] @relation("ToStatus")

  @@unique([projectId, name])
  @@index([projectId, order])
}

model WorkflowTransition {
  id           String @id @default(cuid())
  projectId    String
  fromStatusId String
  toStatusId   String

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStatus WorkflowStatus @relation("FromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus   WorkflowStatus @relation("ToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([projectId, fromStatusId, toStatusId])
}

// ─── Task ────────────────────────────────────────────────

enum TaskPriority {
  none
  low
  medium
  high
  urgent
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  taskNumber  Int
  creatorId   String?
  assigneeId  String?
  title       String
  description Json?
  body        String?      @db.Text
  statusId    String
  priority    TaskPriority @default(none)
  dueDate     DateTime
  startDate   DateTime?
  archivedAt  DateTime?
  alertAcknowledged Boolean @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator          User?              @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  assignee         User?              @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  status           WorkflowStatus     @relation(fields: [statusId], references: [id])
  tags             TaskTag[]
  sourceLinks      TaskLink[]         @relation("SourceTask")
  targetLinks      TaskLink[]         @relation("TargetTask")
  comments         Comment[]
  activityEvents   ActivityEvent[]
  watchers         TaskWatcher[]
  notifications    Notification[]
  customFieldValues CustomFieldValue[]

  @@unique([projectId, taskNumber])
  @@index([projectId, dueDate])
  @@index([projectId, statusId])
  @@index([projectId, archivedAt])
  @@index([projectId, assigneeId])
  @@index([creatorId])
}

enum TaskActivityAction {
  created
  updated
  bulkUpdated
  commented
  archived
  unarchived
  duplicated
}

model ActivityEvent {
  id        String             @id @default(cuid())
  taskId     String
  actorId    String?
  action     TaskActivityAction
  details    Json?
  createdAt  DateTime          @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([actorId])
}

enum NotificationType {
  assigned
  commented
  statusChanged
  mentioned
}

model TaskWatcher {
  taskId     String
  userId     String
  createdAt  DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?
  taskId      String?
  type        NotificationType
  payload     Json             @default("{}")
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  task      Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@index([taskId])
}

// ─── Task Links ──────────────────────────────────────────

enum LinkType {
  blocks
  relates
  parent
  child
}

model TaskLink {
  id           String   @id @default(cuid())
  sourceTaskId String
  targetTaskId String
  linkType     LinkType

  sourceTask Task @relation("SourceTask", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask Task @relation("TargetTask", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId, linkType])
}

// ─── Tags ────────────────────────────────────────────────

model Tag {
  id              String    @id @default(cuid())
  projectId       String
  name            String
  color           String    @default("#6b7280")
  isAutoGenerated Boolean   @default(false)

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskTag[]

  @@unique([projectId, name])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

// ─── Comments ────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  task        Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author      User                @relation(fields: [authorId], references: [id])
  attachments CommentAttachment[]

  @@index([taskId, createdAt])
}

model CommentAttachment {
  id           String   @id @default(cuid())
  commentId    String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  createdAt    DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId, createdAt])
}

// ─── Custom Fields ───────────────────────────────────────

enum CustomFieldType {
  text
  number
  date
  select
}

model CustomField {
  id        String          @id @default(cuid())
  projectId String
  name      String
  type      CustomFieldType
  order     Int             @default(0)
  required  Boolean         @default(false)
  options   Json?

  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  values  CustomFieldValue[]

  @@unique([projectId, name])
  @@index([projectId, order])
}

model CustomFieldValue {
  id            String @id @default(cuid())
  taskId        String
  customFieldId String
  value         Json

  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([taskId, customFieldId])
}
